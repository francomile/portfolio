server {
    listen 80;
    server_name portfolio.fiveinthemoon.com;

    root /var/www/html/portfolio-site/;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }
    location /healthcheck {
        access_log off;
        default_type application/json;
        return 200 '{"status":"ok"}';
    }
}
